\"GLM-5 Turbo\",\n            \"reasoning\": true,\n            \"input\": [\n              \"text\",\n              \"image\"\n            ],\n            \"cost\": {\n              \"input\": 0,\n              \"output\": 0,\n              \"cacheRead\": 0,\n              \"cacheWrite\": 0\n            },\n            \"contextWindow\": 128000,\n            \"maxTokens\": 4096\n          }\n        ]\n      }\n    }\n  },\n  \"agents\": {\n    \"defaults\": {\n      \"model\": {\n        \"primary\": \"kimi/kimi-code\",\n        \"fallbacks\": [\n          \"zai/glm-5-turbo\"\n        ]\n      },\n      \"models\": {\n        \"kimi/kimi-code\": {\n          \"alias\": \"Kimi\"\n        },\n        \"zai/glm-5-turbo\": {\n          \"alias\": \"智谱\"\n        }\n      },\n      \"workspace\": \"/Users/hongzhang/.openclaw/workspace\",\n      \"compaction\": {\n        \"mode\": \"safeguard\"\n      }\n    }\n  },\n  \"tools\": {\n    \"profile\": \"coding\"\n  },\n  \"commands\": {\n    \"native\": \"auto\",\n    \"nativeSkills\": \"auto\",\n    \"restart\": true,\n    \"ownerDisplay\": \"raw\"\n  },\n  \"session\": {\n    \"dmScope\": \"per-channel-peer\"\n  },\n  \"channels\": {\n    \"openclaw-weixin\": {\n      \"accounts\": {}\n    }\n  },\n  \"gateway\": {\n    \"port\": 18789,\n    \"mode\": \"local\",\n    \"bind\": \"loopback\",\n    \"auth\": {\n      \"mode\": \"token\",\n      \"token\": \"9d2ac683de845b5b3cf30e4a3a4fa15c197c5e2a2ac07451\"\n    },\n    \"tailscale\": {\n      \"mode\": \"off\",\n      \"resetOnExit\": false\n    }\n  },\n  \"mcp\": {\n    \"servers\": {\n      \"openspace\": {\n        \"command\": \"openspace-mcp\",\n        \"env\": {\n          \"OPENSPACE_HOST_SKILL_DIRS\": \"/Users/hongzhang/.openclaw/skills\",\n          \"OPENSPACE_WORKSPACE\": \"/Users/hongzhang/.openclaw/workspace/OpenSpace\"\n        },\n        \"toolTimeout\": 600\n      }\n    }\n  },\n  \"skills\": {\n    \"load\": {\n      \"extraDirs\": [\n        \"/User