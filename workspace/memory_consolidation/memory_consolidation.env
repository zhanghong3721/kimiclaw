# ============================================================
# memory_consolidation.env — Memory Consolidation Configuration
# ============================================================
# This file controls how your memory (USER.md) is generated.
# You (the agent) can read and modify these parameters.
# Data source paths and timezone are auto-detected from openclaw.json.
#
# When do changes take effect?
#   - ENABLED / LTM_ENABLED / DIARY_ENABLED: next /reset or new session
#   - LTM / Diary generation settings: next daily reset (~4am)
#   - STM settings (DAYS, MAX_SESSIONS, etc.): next /reset or new session
# To force immediate refresh: python memory_consolidation.py stm

# --- MASTER SWITCH ---
# What: Enable/disable memory consolidation entirely
# When false: plugin still loads but does nothing, USER.md won't be touched
# Safe to change: yes
ENABLED=true

# --- STM (Short-Term Memory) SAMPLING ---
# What: How many days of conversation history to include
# Safe to change: yes
DAYS=30

# What: Maximum total sessions across all channels
# Safe to change: yes (higher = more context but larger USER.md)
MAX_SESSIONS=20

# What: Minimum sessions guaranteed per channel (e.g. Feishu DM, Loopback)
# Safe to change: yes
MIN_PER_CHANNEL=3

# What: Max user messages per session. Takes first N/2 + last N/2.
# Long sessions get a skip marker between head and tail.
# Safe to change: yes
MAX_PER_SESSION=10

# What: Max characters per individual message. Longer messages get truncated
# to front[TL;DR]back format, each half = MAX_CHARS_PER_MESSAGE/2.
# Safe to change: yes
MAX_CHARS_PER_MESSAGE=500

# --- VISUAL MEMORY ---
# What: Max memorized_media/ files listed in the Visual Memory section
# Safe to change: yes
VISUAL_MEMORY=20

# --- GROUP CHAT ---
# What: How to extract user messages from group chat sessions
# Values: trigger_only (only the user who triggered the bot) | all_speakers
# Safe to change: not recommended
GROUP_CHAT_MODE=trigger_only

# What: Include group chat sessions in STM (which feeds into LTM compact)
# ⚠️  HIGHLY RECOMMENDED: DO NOT CHANGE
# Reason: Group chats contain multi-speaker conversations that pollute LTM
# with other people's speech patterns. Also risks leaking private messages
# from other participants into the user's memory profile.
# Safe to change: no
INCLUDE_GROUP=false

# --- LLM FEATURES (LTM + DIARY) ---
# What: Minimum messages required to run LTM compact or diary generation
# Below this threshold: compact falls back to STM only, diary is skipped
# Safe to change: yes
MIN_MESSAGES_FOR_LLM=3

# What: Enable/disable LTM (Long-Term Memory) generation
# When disabled: LTM section shows "disabled by user" message, existing data preserved
# Safe to change: yes, takes effect next daily reset
LTM_ENABLED=true

# What: Enable/disable daily diary generation
# When disabled: Diary section shows "disabled by user" message, existing entries preserved
# Safe to change: yes, takes effect next daily reset
DIARY_ENABLED=true

# What: API key for the compact/diary model
# Leave empty to auto-detect from openclaw.json provider config.
# Only needed if your provider key is NOT in openclaw.json.
# Safe to change: yes
LLM_API_KEY=

# --- OUTPUT ---
# What: Where to write the generated USER.md
# Default: auto — resolves to {workspace}/USER.md from openclaw.json
# Set an explicit path only if you need to override the auto-detected location.
# Can be "auto", a relative path (to script directory), or an absolute path.
# Safe to change: yes
OUTPUT=auto
