{"0":"\u001b[36m[feishu/plugin]\u001b[0m feishu: tool call: exec params={\"command\":\"cd /root/.openclaw/workspace/ai-hedge-fund && source .venv/bin/activate && python -c \\\"\\nimport os\\nfrom dotenv import load_dotenv\\nload_dotenv()\\n\\nfrom src.llm.models import get_model, ModelProvider\\n\\n# 重新测试\\napi_key = os.getenv('MOONSHOT_API_KEY')\\nbase_url = os.getenv('MOONSHOT_BASE_URL')\\nprint(f'Kimi API Key: {api_key[:20]}...' if api_key else 'Not set')\\nprint(f'Kimi Base URL: {base_url}')\\n\\n# 测试模型初始化\\ntry:\\n    model = get_model('kimi-k2.5', ModelProvider.KIMI)\\n    print(f'Model base_url: {model.openai_api_base}')\\n    \\n    # 测试简单调用\\n    response = model.invoke('Say hello in one word')\\n    print(f'Response: {response.content}')\\n    print('API call OK')\\nexcept Exception as e:\\n    print(f'Error: {e}')\\n\\\" 2>&1\",\"timeout\":60} {}","_meta":{"runtime":"node","runtimeVersion":"24.14.1","hostname":"unknown","name":"openclaw","date":"2026-04-16T06:27:19.157Z","logLevelId":3,"logLevelName":"INFO","path":{"fullFilePath":"file:///usr/lib/node_modules/openclaw/dist/subsystem-D2xHvZZd.js:852:46","fileName":"subsystem-D2xHvZZd.js","fileNameWithLine":"subsystem-D2xHvZZd.js:852","fileColumn":"46","fileLine":"852","filePath":"/usr/lib/node_modules/openclaw/dist/subsystem-D2xHvZZd.js","filePathWithLine":"/usr/lib/node_modules/openclaw/dist/subsystem-D2xHvZZd.js:852","method":"console.log"}},"time":"2026-04-16T14:27:19.157+08:00"}
